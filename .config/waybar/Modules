    "tooltip": false,
    "exec": "cat ~/.cache/waybar_gpu/mem_utilization.json",
    "return-type": "json",
    "format": "{text}%"
  },
  "custom/gpu_temp": {
    "interval": 10,
    "tooltip": false,
    "exec": "cat ~/.cache/waybar_gpu/temperature.json",
    "return-type": "json",
    "format": "{text} ΎΜΚ",
  },
  "backlight": {
