  },
  "custom/cpu_temp": {
    "interval": 10,
    "tooltip": false,
    "exec": "~/.config/waybar/scripts/cpu_temp.bash",
    "return-type": "json",
    "format": "{text} ΎΜΚ",
  },
  "memory": {
